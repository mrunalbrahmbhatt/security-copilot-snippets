  "Security Copilot KQL - Risky Signins Query": {
    "prefix": ["sc-kql-risky-signins", "seccopilot-risky-signins"],
    "description": "Pre-built KQL skill for risky sign-ins analysis",
    "body": [
      "      - Name: GetRiskySigninsSummary",
      "        DisplayName: Get Risky Sign-ins Summary",
      "        Description: >",
      "          Summarizes risky sign-in events for a user UPN.",
      "          Requires Entra ID P2 / Identity Protection.",
      "        Inputs:",
      "          - Name: userUPN",
      "            Description: >",
      "              The User Principal Name of the account to analyze.",
      "            Required: true",
      "            DefaultValue: \"\"",
      "",
      "          - Name: timeframe_days",
      "            Description: >",
      "              Lookback window in days. Default is 7.",
      "            Required: false",
      "            DefaultValue: \"7\"",
      "",
      "        Settings:",
      "          Target: Defender",
      "          Template: |-",
      "            let lookback = {{timeframe_days}}d;",
      "            let upn = tolower(\"{{userUPN}}\");",
      "            EntraIdSignInEvents",
      "            | where Timestamp > ago(lookback)",
      "            | where tolower(AccountUpn) == upn",
      "            | where RiskLevelAggregated in (10, 50, 100)",
      "            | project",
      "                Timestamp,",
      "                AccountUpn,",
      "                AccountDisplayName,",
      "                IPAddress,",
      "                Country,",
      "                City,",
      "                RiskLevelAggregated,",
      "                RiskState,",
      "                Application,",
      "                DeviceName,",
      "                OSPlatform,",
      "                Browser",
      "            | order by Timestamp desc",
      "$0"
    ]
  },

  "Security Copilot KQL - Impossible Travel": {
    "prefix": ["sc-kql-impossible-travel", "seccopilot-impossible-travel"],
    "description": "Pre-built KQL skill for impossible travel anomaly detection",
    "body": [
      "      - Name: GetImpossibleTravelAnomalySummary",
      "        DisplayName: Get Impossible Travel Anomaly Summary",
      "        Description: >",
      "          Detects impossible travel anomalies for a user UPN by", 
      "          finding sign-ins from multiple countries.",
      "        Inputs:",
      "          - Name: userUPN",
      "            Description: >",
      "              The User Principal Name of the account to analyze.",
      "            Required: true",
      "            DefaultValue: \"\"",
      "",
      "          - Name: timeframe_days",
      "            Description: >",
      "              Lookback window in days. Default is 180.",
      "            Required: false",
      "            DefaultValue: \"180\"",
      "",
      "        Settings:",
      "          Target: Defender",
      "          Template: |-",
      "            let lookback = {{timeframe_days}}d;",
      "            let upn = tolower(\"{{userUPN}}\");",
      "            let signins =",
      "                EntraIdSignInEvents",
      "                | where Timestamp > ago(lookback)",
      "                | where tolower(AccountUpn) == upn",
      "                | where isnotempty(Country)",
      "                | project Timestamp, AccountUpn, IPAddress, Country, City, Application;",
      "            signins",
      "            | summarize",
      "                SignInCount = count(),",
      "                FirstSeen = min(Timestamp),",
      "                LastSeen = max(Timestamp),",
      "                UniqueIPs = dcount(IPAddress),",
      "                Cities = make_set(City),",
      "                Applications = make_set(Application)",
      "                by Country",
      "            | order by SignInCount desc",
      "$0"
    ]
  },

