  "Security Copilot KQL - Alert Triage": {
    "prefix": ["sc-kql-alert-triage", "seccopilot-alert-triage"],
    "description": "Pre-built KQL skill for alert triage and investigation",
    "body": [
      "      - Name: GetAlertTriageSummary",
      "        DisplayName: Get Alert Triage Summary",
      "        Description: >",
      "          Retrieves and triages recent alerts by severity for investigation.",
      "        Inputs:",
      "          - Name: timeframe_hours",
      "            Description: >",
      "              Lookback window in hours. Default is 24.",
      "            Required: false",
      "            DefaultValue: \"24\"",
      "",
      "          - Name: min_severity",
      "            Description: >",
      "              Minimum severity to include: Low, Medium, High, Informational.",
      "            Required: false",
      "            DefaultValue: \"Medium\"",
      "",
      "        Settings:",
      "          Target: Defender",
      "          Template: |-",
      "            let lookback = {{timeframe_hours}}h;",
      "            AlertInfo",
      "            | where Timestamp > ago(lookback)",
      "            | where Severity in (\"High\", \"Medium\")",
      "            | join kind=leftouter (",
      "                AlertEvidence",
      "                | where Timestamp > ago(lookback)",
      "            ) on AlertId",
      "            | summarize",
      "                EvidenceCount = count(),",
      "                Entities = make_set(EntityType),",
      "                FirstSeen = min(Timestamp),",
      "                LastSeen = max(Timestamp)",
      "                by AlertId, Title, Severity, Category",
      "            | order by Severity asc, LastSeen desc",
      "$0"
    ]
  },

